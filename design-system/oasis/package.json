{
  "name": "@lyel/oasis",
  "version": "1.0.0",
  "description": "Lyel Oasis – design tokens (JSON) with SCSS (web) and TS (mobile) exports, including responsive breakpoints.",
  "license": "UNLICENSED",
  "private": false,
  "author": "Nestor TCHISSAMBOT MAKOSSO",
  "main": "dist/tokens/index.ts",
  "types": "dist/tokens/index.ts",
  "exports": {
    ".": {
      "types": "./dist/tokens/index.ts",
      "default": "./dist/tokens/index.ts"
    },
    "./scss": "./dist/scss/oasis.scss",
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    }
  },
  "files": [
    "dist",
    "tokens"
  ],
  "publishConfig": {
    "registry": "https://lyel-packages-023704516286.d.codeartifact.eu-west-3.amazonaws.com/npm/lyel-libraries/"
  },
  "scripts": {
    "build": "node build/run.mjs",
    "build:tokens": "node build/run.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
